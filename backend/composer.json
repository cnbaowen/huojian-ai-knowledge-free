{
  "name": "huojian/ai-knowledge-free",
  "description": "Commercial-aligned knowledge management and internal Q&A free edition",
  "type": "project",
  "license": "Apache-2.0",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^13.20"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "platform": {
      "php": "8.3.0"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
